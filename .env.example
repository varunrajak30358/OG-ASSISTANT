# OG Assistant — Environment Variables
# Copy this file to .env and fill in your values
# Get free Gemini API key at: https://aistudio.google.com/app/api-keys

# ── Required ──────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here

# ── Voice ─────────────────────────────────────────────────────────────────────
# Options: Aoede (female), Orus (male), Puck (male), Lyra (female)
OG_VOICE=Aoede

# ── Security ──────────────────────────────────────────────────────────────────
# PIN required for destructive power actions (shutdown/restart/sleep/lock)
OG_PIN=1234

# ── Notifications ─────────────────────────────────────────────────────────────
# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID (get from @userinfobot)
TELEGRAM_CHAT_ID=

# Email address for email notifications
NOTIFICATION_EMAIL=varunrajak30@gmail.com

# ── Developer Integrations ────────────────────────────────────────────────────
# GitHub username for GitHub integration
GITHUB_USERNAME=

# ── Optional: Multi-Model Support ────────────────────────────────────────────
# DeepSeek API key for coding tasks (optional, falls back to Gemini)
DEEPSEEK_API_KEY=your_deepseek_api_key_here


# OpenAI API key for embeddings/vision (optional)
OPENAI_API_KEY=
